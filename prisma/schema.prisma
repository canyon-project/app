generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String      @id
  username      String
  nickname String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Repo {
  id                String   @id
    provider          String
  pathWithNamespace String   @map("path_with_namespace")
  description       String
  config            String
  bu                String
  createdAt         DateTime @map("created_at")
  updatedAt         DateTime @map("updated_at")
}

model Commit {
  id      String @id
  content Json
}

model MergeRequest {
  id      String @id
  content Json
}

model Diff {
  id String @id @default(cuid())

  provider  String
  repoID    String @map("repo_id")
  from      String
  to        String
  path      String
  additions Int[]
  deletions Int[]
  subject   String
  subjectID String @map("subject_id")
}

model Infra {
  id                     String   @id
  name                   String
  value                  String   @db.Text
  createdAt              DateTime @default(now()) @map("createdOn")
  updatedAt              DateTime @updatedAt @map("updatedOn")
  isEncrypted            Boolean  @default(false) @map("isEncrypted")
  lastSyncedEnvFileValue String?  @map("lastSyncedEnvFileValue")

  @@map("canyon_next_infra_config")
}